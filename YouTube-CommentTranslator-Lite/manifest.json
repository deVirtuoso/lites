{
  "manifest_version": 3,
  "name": "YouTube Comment Translator Lite",
  "description": "Auto-translate YouTube comments and live chat.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.plasmo.6c567d50.png",
    "32": "icons/icon32.plasmo.76b92899.png",
    "48": "icons/icon48.plasmo.aced7582.png",
    "128": "icons/icon128.plasmo.3c1ed2d2.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.plasmo.6c567d50.png",
      "32": "icons/icon32.plasmo.76b92899.png",
      "48": "icons/icon48.plasmo.aced7582.png",
      "128": "icons/icon128.plasmo.3c1ed2d2.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://translate.googleapis.com/*",
    "https://translate-pa.googleapis.com/*",
    "https://edge.microsoft.com/*",
    "https://api-edge.cognitive.microsofttranslator.com/*",
    "https://translate.yandex.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/translator.js"],
      "css": ["content/translator.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}

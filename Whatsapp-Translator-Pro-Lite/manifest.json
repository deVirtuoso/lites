{
  "manifest_version": 3,
  "name": "WhatsApp Translator Lite",
  "description": "Auto-translate WhatsApp Web messages with a minimal local settings popup.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.plasmo.6c567d50.png",
    "32": "icons/icon32.plasmo.76b92899.png",
    "48": "icons/icon48.plasmo.aced7582.png",
    "64": "icons/icon64.plasmo.8bb5e6e0.png",
    "128": "icons/icon128.plasmo.3c1ed2d2.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.plasmo.6c567d50.png",
      "32": "icons/icon32.plasmo.76b92899.png",
      "48": "icons/icon48.plasmo.aced7582.png",
      "64": "icons/icon64.plasmo.8bb5e6e0.png",
      "128": "icons/icon128.plasmo.3c1ed2d2.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://translate.googleapis.com/*",
    "https://translate-pa.googleapis.com/*",
    "https://edge.microsoft.com/*",
    "https://api-edge.cognitive.microsofttranslator.com/*",
    "https://translate.yandex.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content/whatsapp-translator.js"],
      "css": ["content/whatsapp-translator.css"],
      "run_at": "document_idle"
    }
  ]
}
